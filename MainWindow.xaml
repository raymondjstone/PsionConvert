<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="PsionConvert.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:PsionConvert"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Psion DB Converter">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Padding="16,12,16,8" Spacing="8">
            <Button x:Name="OpenButton" Content="Open File..." Click="OpenButton_Click"
                    Style="{StaticResource AccentButtonStyle}"/>
            <Button x:Name="CopyButton" Content="Copy as Text" Click="CopyButton_Click"
                    IsEnabled="False"/>
            <Button x:Name="SaveButton" Content="Save as Text..." Click="SaveButton_Click"
                    IsEnabled="False"/>
            <TextBlock x:Name="FilePathText" VerticalAlignment="Center"
                       Foreground="{ThemeResource SystemBaseMediumColor}"
                       FontSize="12" MaxWidth="400"/>
        </StackPanel>

        <!-- Record list -->
        <ListView Grid.Row="1" x:Name="RecordsList"
                  Margin="16,0,16,0"
                  SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="local:RecordViewModel">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="150"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{x:Bind Field1}" TextTrimming="CharacterEllipsis" Margin="0,0,8,0"/>
                        <TextBlock Grid.Column="1" Text="{x:Bind Field2}" TextTrimming="CharacterEllipsis" Margin="0,0,8,0"/>
                        <TextBlock Grid.Column="2" Text="{x:Bind Field3}" TextTrimming="CharacterEllipsis"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
            <ListView.Header>
                <Grid Padding="16,8,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="150"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Field 1" FontWeight="SemiBold" Margin="0,0,8,0"/>
                    <TextBlock Grid.Column="1" Text="Field 2" FontWeight="SemiBold" Margin="0,0,8,0"/>
                    <TextBlock Grid.Column="2" Text="Field 3" FontWeight="SemiBold"/>
                </Grid>
            </ListView.Header>
        </ListView>

        <!-- Status bar -->
        <Grid Grid.Row="2" Padding="16,6">
            <TextBlock x:Name="StatusText" HorizontalAlignment="Left"
                       Foreground="{ThemeResource SystemBaseMediumColor}" FontSize="12"/>
            <TextBlock x:Name="FormatText" HorizontalAlignment="Right"
                       Foreground="{ThemeResource SystemBaseMediumColor}" FontSize="12"/>
        </Grid>
    </Grid>
</Window>
